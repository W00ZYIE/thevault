{
  "buildCommand": "npm install && cd thevault && npm install && npm run build",
  "outputDirectory": "thevault/dist",
  "installCommand": "echo 'skip'",
  "routes": [
    { "src": "/api/checkout", "dest": "/api/checkout.js" },
    { "src": "/api/stripe-webhook", "dest": "/api/stripe-webhook.js" },
    { "src": "/", "dest": "/landing.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
